# PostgreSQL 连接串示例，供 Prisma CLI 在本地执行 generate / migrate 时读取
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/neo_noumi?schema=public"

# Hyperdrive 本地开发直连数据库的连接串示例；binding 名称为 HYPERDRIVE
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE="postgresql://postgres:postgres@localhost:5432/neo_noumi?schema=public"

# Better Auth 签名密钥，本地可通过 `bunx @better-auth/cli@latest secret` 生成
BETTER_AUTH_SECRET="replace-with-a-random-secret"

# Better Auth 对外访问地址，本地 Vite 默认端口为 5173
BETTER_AUTH_URL="http://localhost:5173"

# Neo Noumi 对外访问地址；生产环境建议配置为 Worker 自身 HTTPS origin
NEO_NOUMI_PUBLIC_BASE_URL="http://localhost:5173"

# Project workspace 操作签名密钥；生产环境应通过 Wrangler secret 注入
WORKSPACE_SIGNING_SECRET="replace-with-a-random-workspace-signing-secret"

# Project workspace 前端直传 R2 所需 S3 API 凭证；生产环境应通过 Wrangler secret 注入
PROJECT_WORKSPACE_BUCKET_NAME="neo-noumi-workspaces"
R2_ACCOUNT_ID="replace-with-cloudflare-account-id"
R2_ACCESS_KEY_ID="replace-with-r2-access-key-id"
R2_SECRET_ACCESS_KEY="replace-with-r2-secret-access-key"

# 是否启用沙盒内真实 Claude Code CLI；未开启时使用 fallback 验证 Neo Noumi/PG 链路
NEO_NOUMI_ENABLE_REAL_CLAUDE="0"

# 本地 Docker sandbox 默认没有 /dev/fuse；本地开发可禁用 R2/s3fs workspace 挂载
NEO_NOUMI_DISABLE_WORKSPACE_MOUNT="1"

# 真实 Claude Code 执行所需平台级 fallback 凭证；只在 Worker AI Proxy 转发时使用，不会注入 sandbox
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL="https://api.anthropic.com"
AI_PROXY_AUTH_HEADER="anthropic"
# 用户级 AI Proxy credential 的 AES-GCM 加密密钥；生产环境应通过 Wrangler secret 注入
AI_PROXY_CREDENTIAL_SECRET="replace-with-a-random-ai-proxy-secret"
CLAUDE_MODEL="claude-sonnet-4-6"
