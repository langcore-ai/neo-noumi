# PostgreSQL 连接串示例，供 Prisma CLI 在本地执行 generate / migrate 时读取
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/neo_noumi?schema=public"

# Hyperdrive 本地开发直连数据库的连接串示例；binding 名称为 HYPERDRIVE
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE="postgresql://postgres:postgres@localhost:5432/neo_noumi?schema=public"
