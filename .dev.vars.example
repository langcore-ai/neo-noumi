# Cloudflare Workers 本地开发环境变量示例
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/neo_noumi?schema=public"

# Better Auth 签名密钥，本地可通过 `bunx @better-auth/cli@latest secret` 生成
BETTER_AUTH_SECRET="replace-with-a-random-secret"

# Better Auth 对外访问地址，本地 Vite 默认端口为 5173
BETTER_AUTH_URL="http://localhost:5173"

# Neo Noumi 对外访问地址；生产环境建议配置为 Worker 自身 HTTPS origin
NEO_NOUMI_PUBLIC_BASE_URL="http://localhost:5173"

# 是否启用沙盒内真实 Claude Code CLI；本地无凭证时保持 0，仍可验证 Neo Noumi/PG 链路
NEO_NOUMI_ENABLE_REAL_CLAUDE="0"

# 真实 Claude Code 执行所需凭证；本地如需真跑再填写
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL="https://api.anthropic.com"
CLAUDE_MODEL="claude-sonnet-4-6"
CLAUDE_CODE_OAUTH_TOKEN=""
