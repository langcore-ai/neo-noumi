generator client {
  provider = "prisma-client"
  runtime  = "cloudflare"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id
  name               String
  email              String
  emailVerified      Boolean
  image              String?
  username           String?             @unique
  displayUsername    String?
  createdAt          DateTime
  updatedAt          DateTime
  sessions           Session[]
  accounts           Account[]
  projects           Project[]
  chatSessions       ChatSession[]
  userContainer      UserContainer?
  aiProxyCredentials AiProxyCredential[]
  aiProxyTokens      AiProxyToken[]
  aiProxyRequestLogs AiProxyRequestLog[]
  claudeCodeConfig   UserClaudeCodeConfig?

  @@unique([email])
  @@map("user")
}

/// 用户级 Claude Code 配置。
model UserClaudeCodeConfig {
  /// 配置记录唯一标识。
  id               String   @id
  /// 所属用户 ID；每个用户最多一份配置。
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 对应 ~/.claude/config.json 的 JSON 内容。
  claudeConfigJson Json     @default("{}")
  /// 对应 ~/.claude.json 的 JSON 内容。
  claudeJson       Json     @default("{}")
  /// 创建时间。
  createdAt        DateTime @default(now())
  /// 更新时间。
  updatedAt        DateTime @updatedAt

  @@map("user_claude_code_configs")
}

model Project {
  id          String        @id
  name        String
  description String?
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    ChatSession[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@index([userId, updatedAt])
  @@map("projects")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model ChatSession {
  id                    String                 @id
  title                 String?
  userId                String
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId             String
  project               Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workerEpoch           Int                    @default(0)
  nextClientSequence    Int                    @default(1)
  workerStatus          String                 @default("idle")
  containerStatus       String                 @default("stopped")
  sandboxId             String?
  runnerProcessId       String?
  workerAccessToken     String?
  externalMetadata      Json                   @default("{}")
  requiresActionDetails Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  lastHeartbeatAt       DateTime?
  clientEvents          ChatClientEvent[]
  workerEvents          ChatWorkerEvent[]
  internalEvents        ChatInternalEvent[]
  deliveryUpdates       ChatDeliveryUpdate[]
  operationLogs         ChatOperationLog[]
  sessionStoreFiles     ChatSessionStoreFile[]
  aiProxyTokens         AiProxyToken[]
  aiProxyRequestLogs    AiProxyRequestLog[]

  @@index([userId, updatedAt])
  @@index([projectId, updatedAt])
  @@map("chat_sessions")
}

model AiProxyCredential {
  id               String              @id
  userId           String
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  provider         String              @default("anthropic")
  baseUrl          String
  apiKeyCiphertext String
  isDefault        Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?
  requestLogs      AiProxyRequestLog[]

  @@index([userId, isDefault])
  @@map("ai_proxy_credentials")
}

model AiProxyToken {
  id          String              @id
  tokenHash   String              @unique
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId   String
  session     ChatSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sandboxId   String
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime            @default(now())
  requestLogs AiProxyRequestLog[]

  @@index([userId, expiresAt])
  @@index([sessionId, revokedAt])
  @@map("ai_proxy_tokens")
}

model AiProxyRequestLog {
  id              String                    @id
  userId          String
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId       String
  session         ChatSession               @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tokenId         String
  token           AiProxyToken              @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  credentialId    String?
  credential      AiProxyCredential?        @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  provider        String
  requestMethod   String
  requestUrl      String
  requestPath     String
  upstreamUrl     String
  upstreamBaseUrl String
  statusCode      Int?
  durationMs      Int?
  requestBytes    Int
  responseBytes   Int?
  errorMessage    String?
  startedAt       DateTime                  @default(now())
  completedAt     DateTime?
  createdAt       DateTime                  @default(now())
  payload         AiProxyRequestLogPayload?

  @@index([userId, startedAt])
  @@index([sessionId, startedAt])
  @@index([statusCode, startedAt])
  @@map("ai_proxy_request_logs")
}

model AiProxyRequestLogPayload {
  id                     String            @id
  logId                  String            @unique
  log                    AiProxyRequestLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  requestHeaders         Json
  requestBody            String?
  upstreamRequestHeaders Json
  responseHeaders        Json?
  responseBody           String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@map("ai_proxy_request_log_payloads")
}

model UserContainer {
  id              String   @id
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sandboxId       String?
  containerStatus String   @default("stopped")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("user_containers")
}

model ChatClientEvent {
  id          Int         @id @default(autoincrement())
  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventId     String
  sequenceNum Int
  eventType   String
  source      String
  payload     Json
  status      String      @default("queued")
  createdAt   DateTime    @default(now())

  @@unique([sessionId, eventId])
  @@unique([sessionId, sequenceNum])
  @@index([sessionId, status, sequenceNum])
  @@index([sessionId, sequenceNum])
  @@map("chat_client_events")
}

model ChatWorkerEvent {
  id          Int         @id @default(autoincrement())
  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventId     String
  workerEpoch Int
  eventType   String
  payload     Json
  ephemeral   Boolean     @default(false)
  createdAt   DateTime    @default(now())

  @@unique([sessionId, eventId])
  @@index([sessionId, id])
  @@map("chat_worker_events")
}

model ChatInternalEvent {
  id            Int         @id @default(autoincrement())
  sessionId     String
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventId       String
  workerEpoch   Int
  eventType     String
  payload       Json
  eventMetadata Json?
  isCompaction  Boolean     @default(false)
  agentId       String?
  createdAt     DateTime    @default(now())

  @@unique([sessionId, eventId])
  @@index([sessionId, agentId, id])
  @@map("chat_internal_events")
}

model ChatDeliveryUpdate {
  id          Int         @id @default(autoincrement())
  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventId     String
  status      String
  workerEpoch Int
  createdAt   DateTime    @default(now())

  @@index([sessionId, eventId])
  @@map("chat_delivery_updates")
}

model ChatOperationLog {
  id        Int         @id @default(autoincrement())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  direction String
  category  String
  eventId   String?
  agentId   String?
  toolName  String?
  toolUseId String?
  requestId String?
  payload   Json
  createdAt DateTime    @default(now())

  @@index([sessionId, id])
  @@map("chat_operation_log")
}

model ChatSessionStoreFile {
  id         Int         @id @default(autoincrement())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  projectKey String
  subpath    String
  content    String
  metadata   Json?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([sessionId, projectKey, subpath])
  @@map("chat_session_store_files")
}
